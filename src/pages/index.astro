---
import '../styles/global.css';
import { site } from '../config/site';
import { HandModel } from '../components/HandModel';
const contactHref = `mailto:${site.contactEmail}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.url.origin).href;
---

<html lang="en" class="h-auto sm:h-[100dvh] font-neue-haas-grotesque">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={site.description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<title>{site.title}</title>
		<meta property="og:title" content={site.title} />
		<meta property="og:description" content={site.description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		{import.meta.env.PROD && (
			<script defer src="https://cloud.umami.is/script.js" data-website-id={site.umamiWebsiteId} />
		)}
	</head>
	<body class="flex h-auto sm:h-[100dvh] flex-col bg-[#E6EDF7] text-blue-900 antialiased overflow-x-hidden">
		<div class="relative mx-auto grid w-full flex-none min-h-0 sm:flex-1 grid-rows-[auto_auto_auto] sm:grid-rows-[auto_1fr_auto] pt-4 pb-2 pointer-events-none">
			<!-- Header -->
			<header class="mb-4 flex items-start justify-between relative z-30 pointer-events-auto px-2 sm:px-6">
				<a href="/" class="flex items-center gap-2">
					<img src="/MasTer-Hand.png" alt="" class="h-16 w-auto object-contain" width="64" height="64" />
					<span class="block text-2xl font-bold leading-none tracking-tight">
						THOUGHTFORM<br />WORLDWIDE
					</span>
				</a>
					<a
						href={contactHref}
						class="mt-1.5 sm:mt-0 rounded-md border border-blue-800 px-4 py-2 text-sm font-medium transition-colors hover:bg-blue-900 hover:text-white inline-block"
					>
					Contact
				</a>
			</header>

			<!-- Main content -->
			<main class="flex min-h-0 flex-col relative z-30 pointer-events-none">
				<div class="grid gap-12 lg:grid-cols-[1fr_auto] lg:items-center lg:gap-16 pointer-events-auto px-2 sm:px-6">
					<div class="w-full">
						<h1 class="w-full text-4xl font-normal leading-[1.1] sm:text-5xl lg:text-7xl xl:text-8xl">
							<span class="sm:hidden">Modern solutions for the independent landscape.</span>
							<span class="hidden sm:inline">Modern solutions <br />for the independent <br />landscape.</span>
						</h1>
					</div>
				</div>

				<!-- Mobile (< sm): taller canvas so hover/float isn't clipped; sm+: fixed full viewport -->
			<div
				id="hand-canvas"
				class="w-full aspect-[3/4] relative z-10 sm:fixed sm:inset-0 sm:aspect-auto sm:h-[115dvh] sm:w-full sm:pointer-events-none transition-opacity duration-700 ease-in-out"
				aria-hidden="true"
			>
					<div class="pointer-events-auto sm:pointer-events-none h-full w-full">
						<HandModel client:load />
					</div>
				</div>
				<div class="min-h-0 flex-1 pointer-events-none hidden sm:block" aria-hidden="true"></div>

				<!-- Mobile (< sm): control pane slot directly above the text paragraph -->
				<div id="mobile-control-pane-slot" class="sm:hidden w-full shrink-0 px-2 pointer-events-auto" aria-hidden="true"></div>

				<div class="max-w-2xl mb-3 sm:mb-6 pointer-events-auto px-2 sm:px-6">
					<!-- <h2 class="mb-4 text-xl font-bold">
						We built a studio that delivers the creative power your brand and team needs.
					</h2> -->
					<p class="mb-8 leading-relaxed max-w-sm text-blue-800/90">
						Thoughtform Worldwide is a boutique development studio focused on the intersection of technical precision and cultural influence. We provide specialist digital and physical infrastructure for creators and brands who have outgrown standard solutions. Referral-based support for those building what’s next.
					</p>
				<div class="flex flex-col sm:flex-row gap-3">
					<a
						href={contactHref}
						class="w-full sm:w-auto rounded-md bg-blue-900 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-blue-800 inline-block text-center"
					>
					Build with us
					</a>
					<button
						id="brands-btn"
						type="button"
						class="hidden sm:inline-block rounded-md border border-blue-800 px-6 py-3 text-sm font-medium transition-colors hover:bg-blue-900 hover:text-white text-center cursor-pointer"
					>
					Brands We've Touched
					</button>
				</div>
				</div>
			</main>

			<!-- Footer -->
			<footer class="flex flex-col gap-2 border-t border-blue-300/30 pt-3 sm:flex-row sm:items-center sm:justify-between relative z-30 pointer-events-auto text-base sm:text-[1.5em] px-2 sm:px-6">
				<div class="order-4 sm:order-0 flex flex-wrap gap-x-8 gap-y-2 w-full sm:w-auto justify-center sm:justify-start">
					<a href={contactHref} class="hidden sm:flex items-center gap-1 hover:underline">
						<span>→</span>
						{site.contactEmail}
					</a>
					<span class="flex items-center gap-1 pt-1 sm:pt-0">
						<span>→</span>
						Los Angeles / Richmond, VA
					</span>
				</div>
				<a
					href={contactHref}
					class="order-1 sm:hidden rounded-md border border-blue-800 px-4 py-2 text-sm font-medium transition-colors hover:bg-blue-900 hover:text-white block text-center"
				>
					Contact: {site.contactEmail}
				</a>
				<div class="order-2 sm:order-1 flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
					<a
						href={site.instagramUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="rounded-md border border-blue-800 px-4 py-2 text-sm font-medium transition-colors hover:bg-blue-900 hover:text-white text-center"
					>
						<span class="sm:hidden">Follow us on Instagram</span>
						<span class="hidden sm:inline">Instagram</span>
					</a>
					<a
						href={site.soundcloudUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="rounded-md border border-blue-800 px-4 py-2 text-sm font-medium transition-colors hover:bg-blue-900 hover:text-white text-center"
					>
						<span class="sm:hidden">Listen on SoundCloud</span>
						<span class="hidden sm:inline">SoundCloud</span>
					</a>
				</div>
			</footer>

		<!-- 3D hand: on sm+ fixed full viewport behind content; on mobile in-flow square (see main). -->

		<!-- Brands panel: fades in when 3D canvas fades out -->
		<div
			id="brands-panel"
			class="hidden sm:block fixed inset-0 z-20 pointer-events-none opacity-0 transition-opacity duration-700 ease-in-out"
		>
			<div class="absolute top-28 right-6 bottom-20 left-[50%] flex flex-col gap-6 overflow-y-auto">
				<!-- Brand logo grid: 3 cols × 2 rows -->
				<div class="grid grid-cols-3 border border-blue-900/20 rounded-md overflow-hidden">
					<div class="flex flex-col items-center justify-center gap-3 border-r border-b border-blue-900/20 p-6">
						<div class="h-16 w-16 bg-blue-900/10 rounded"></div>
						<span class="font-bold text-sm tracking-widest text-center uppercase">Interface<br/>AG</span>
					</div>
					<div class="flex flex-col items-center justify-center gap-3 border-r border-b border-blue-900/20 p-6">
						<div class="h-16 w-16 bg-blue-900/10 rounded"></div>
						<span class="font-bold text-sm tracking-widest text-center uppercase">Neural<br/>Codex</span>
					</div>
					<div class="flex flex-col items-center justify-center gap-3 border-b border-blue-900/20 p-6">
						<div class="h-16 w-16 bg-blue-900/10 rounded"></div>
						<span class="font-bold text-sm tracking-widest text-center uppercase">Systema<br/>Sync</span>
					</div>
					<div class="flex flex-col items-center justify-center gap-3 border-r border-blue-900/20 p-6">
						<div class="h-16 w-16 bg-blue-900/10 rounded"></div>
						<span class="font-bold text-sm tracking-widest text-center uppercase">Kinetic<br/>Dynamics</span>
					</div>
					<div class="flex flex-col items-center justify-center gap-3 border-r border-blue-900/20 p-6">
						<div class="h-16 w-16 bg-blue-900/10 rounded"></div>
						<span class="font-bold text-sm tracking-widest text-center uppercase">Arcade<br/>Studios</span>
					</div>
					<div class="flex flex-col items-center justify-center gap-3 p-6">
						<div class="h-16 w-16 bg-blue-900/10 rounded"></div>
						<span class="font-bold text-sm tracking-widest text-center uppercase">Velocity<br/>Lab</span>
					</div>
				</div>

				<!-- Engagements table -->
				<div class="grid grid-cols-2 border border-blue-900/20 rounded-md overflow-hidden">
					<div class="border-r border-blue-900/20 p-6">
						<h3 class="mb-4 text-xs font-bold tracking-[0.2em] uppercase">Direct Engagements</h3>
						<ul class="space-y-2 text-sm">
							<li class="flex justify-between gap-4"><span>Arcade Studios</span><span class="text-blue-800/60">(Identity &amp; Web)</span></li>
							<li class="flex justify-between gap-4"><span>Spectrum</span><span class="text-blue-800/60">(Frontend Arch.)</span></li>
							<li class="flex justify-between gap-4"><span>Velocity</span><span class="text-blue-800/60">(Strategy)</span></li>
						</ul>
					</div>
					<div class="p-6">
						<h3 class="mb-4 text-xs font-bold tracking-[0.2em] uppercase">In Partnership with Agencies</h3>
						<ul class="space-y-2 text-sm">
							<li class="flex justify-between gap-4"><span>Interface AG</span><span class="text-blue-800/60">(Frontend Dev)</span></li>
							<li class="flex justify-between gap-4"><span>Neural Codex</span><span class="text-blue-800/60">(UI/UX)</span></li>
							<li class="flex justify-between gap-4"><span>Systema Sync</span><span class="text-blue-800/60">(Web Platform)</span></li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</div>
	<script>
		const brandsBtn = document.getElementById('brands-btn');
		const handCanvas = document.getElementById('hand-canvas');
		const brandsPanel = document.getElementById('brands-panel');
		if (brandsBtn && handCanvas && brandsPanel) {
			brandsBtn.addEventListener('click', () => {
				const showing3d = handCanvas.style.opacity !== '0';
				const controlsPanel = document.querySelector<HTMLElement>('[aria-label="Controls"]');

				handCanvas.style.opacity = showing3d ? '0' : '1';
				handCanvas.style.pointerEvents = showing3d ? 'none' : '';

				brandsPanel.style.opacity = showing3d ? '1' : '0';
				brandsPanel.style.pointerEvents = showing3d ? 'auto' : 'none';

				if (controlsPanel) {
					controlsPanel.style.transition = 'opacity 700ms ease-in-out';
					controlsPanel.style.opacity = showing3d ? '0' : '1';
					controlsPanel.style.pointerEvents = showing3d ? 'none' : '';
				}
			});
		}
	</script>
	</body>
</html>
